{
    "name": "bisnis-rinzi",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:sso": "npm run dev -w apps/login-sso",
        "dev:admin": "npm run dev -w apps/admin-dashboard",
        "dev:toko": "npm run dev -w apps/portal-toko",
        "dev:sewa": "npm run dev -w apps/portal-sewa",
        "dev:web": "concurrently \"npm run dev:sso\" \"npm run dev:toko\" \"npm run dev:sewa\" \"npm run dev:admin\"",
        "build": "npm run build --workspaces",
        "lint": "npm run lint --workspaces"
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@primevue/themes": "^4.5.4",
        "@tailwindcss/vite": "^4.3.1",
        "@vee-validate/zod": "^4.15.1",
        "@vueuse/core": "^14.3.0",
        "axios": "^1.18.0",
        "dayjs": "^1.11.21",
        "jwt-decode": "^4.0.0",
        "material-symbols": "^0.45.2",
        "nprogress": "^0.2.0",
        "pinia": "^3.0.4",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "tailwindcss": "^4.3.1",
        "vee-validate": "^4.15.1",
        "vue-router": "^5.1.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "concurrently": "^10.0.3",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.4",
        "sass": "^1.101.0",
        "sass-embedded": "^1.100.0",
        "typescript": "^6.0.3",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^32.1.0",
        "vite-plugin-checker": "^0.14.4",
        "vue-tsc": "^3.3.5"
    },
    "overrides": {
        "jspdf": {
            "dompurify": "^3.4.11"
        }
    },
    "allowScripts": {
        "@parcel/watcher@2.5.6": true,
        "core-js@3.49.0": true
    }
}