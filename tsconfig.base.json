{
    "compilerOptions": {
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "allowJs": false,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": [
            "vite/client"
        ],
        "baseUrl": ".",
        "paths": {
            "@frontend/*": [
                "packages/frontend/*"
            ]
        }
    }
}